# OmniPath AI — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.

# ── Flask Core ─────────────────────────────────────────────────────────
# REQUIRED: Set a strong, random secret key.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-secure-random-string

# ── Debug Mode ─────────────────────────────────────────────────────────
# Set to "true" ONLY in local development. NEVER set true in production.
# When false: host is bound to 127.0.0.1 (localhost only)
# When true:  host is bound to 0.0.0.0 (all interfaces) — DEV ONLY
FLASK_DEBUG=false

# ── Server Port ─────────────────────────────────────────────────────────
PORT=5000
